{
  "version": 2,
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node",
      "config": {
        "runtime": "nodejs20.x"
      }
    },
    {
      "src": "dist/client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/(.*)\\.(ico|png|jpg|jpeg|svg|txt|xml|json)",
      "dest": "/client/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}